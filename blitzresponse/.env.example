# ============================================================
# BlitzResponse.io — Environment Variables
# ============================================================
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Database (Neon PostgreSQL) ───────────────────────────────
# Get from: https://console.neon.tech → Project → Connection Details
# Use the POOLED connection string for serverless compatibility.
DATABASE_URL="postgresql://user:pass@ep-xxxxx.us-east-2.aws.neon.tech/blitzresponse?sslmode=require"

# ── Auth (Clerk) ─────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# Clerk routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── Voice AI (Retell) ───────────────────────────────────────
# Get from: https://www.retellai.com/dashboard → Settings → API Keys
RETELL_API_KEY=key_xxxxx
RETELL_WEBHOOK_SECRET=whsec_xxxxx
# Agent ID created via Retell dashboard or API
RETELL_AGENT_ID=agent_xxxxx

# ── Telephony (Twilio) ──────────────────────────────────────
# Get from: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
# Buy a number at: Console → Phone Numbers → Buy a Number
TWILIO_PHONE_NUMBER=+1234567890

# ── LLM — OpenAI (quoting + photo analysis) ─────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxx

# ── LLM — Groq (fast triage) ────────────────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxx

# ── Google Calendar (OAuth) ──────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# ── File Storage (Supabase) ──────────────────────────────────
# Get from: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# ── Payments (Stripe) ───────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Stripe Price IDs (create products first in Stripe dashboard)
STRIPE_PRICE_STARTER=price_xxxxx
STRIPE_PRICE_PRO=price_xxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxx
STRIPE_PRICE_SETUP_FEE=price_xxxxx

# ── Email (Resend) ──────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=dispatch@blitzresponse.io

# ── Background Jobs (Trigger.dev) ───────────────────────────
# Get from: https://cloud.trigger.dev → Project → API Keys
TRIGGER_SECRET_KEY=tr_xxxxx

# ── Monitoring (Sentry) ─────────────────────────────────────
# Get from: https://sentry.io → Project → Settings → Client Keys
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ── Business Defaults ───────────────────────────────────────
# Used in ROI calculations when a company has no historical job data yet.
DEFAULT_AVG_JOB_VALUE=4500

# Fallback pricing per sq ft when company hasn't uploaded a pricing matrix.
# Format: JSON string — parsed at runtime.
DEFAULT_PRICING_FALLBACK='{"water_extraction":{"perSqFt":3.50,"minimum":500},"structural_drying":{"perSqFt":4.00,"minimum":750},"mold_remediation":{"perSqFt":12.00,"minimum":1500},"fire_smoke_cleanup":{"perSqFt":6.50,"minimum":1000},"content_cleaning":{"perSqFt":2.50,"minimum":350}}'
